<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Mitiphy report — {{ case_id }}</title>
  <style>
    :root { color-scheme: light dark; }
    body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; max-width: 920px; margin: 2em auto; padding: 0 1em; line-height: 1.5; }
    h1 { margin-bottom: 0.2em; }
    .meta { color: #666; font-size: 0.9em; }
    .score { display: inline-block; padding: 0.4em 0.8em; border-radius: 0.5em; font-weight: bold; color: #fff; }
    .score-low { background: #2a8a3e; }
    .score-med { background: #c98a14; }
    .score-high { background: #b53929; }
    table { border-collapse: collapse; width: 100%; margin: 1em 0; }
    th, td { border: 1px solid #ccc; padding: 0.4em 0.6em; text-align: left; vertical-align: top; }
    th { background: #f4f4f4; }
    @media (prefers-color-scheme: dark) {
      th { background: #222; }
      th, td { border-color: #444; }
    }
    code { background: rgba(127,127,127,0.15); padding: 0.1em 0.3em; border-radius: 3px; }
    .sev-critical { color: #b53929; font-weight: bold; }
    .sev-high { color: #c95014; font-weight: bold; }
    .sev-medium { color: #c98a14; }
    .sev-low { color: #888; }
    .sev-info { color: #4a4a4a; }
    .footer { margin-top: 3em; font-size: 0.8em; color: #888; }
  </style>
</head>
<body>
  <h1>Mitiphy report</h1>
  <div class="meta">
    Case <code>{{ case_id }}</code> &middot; Generated {{ created_at_iso }}
  </div>

  <h2>Target</h2>
  <p><code>{{ target.value }}</code> &mdash; type <strong>{{ target.type }}</strong></p>

  <h2>Risk score</h2>
  {% set s = score.score %}
  {% if s >= 70 %}{% set cls = "score-high" %}{% elif s >= 40 %}{% set cls = "score-med" %}{% else %}{% set cls = "score-low" %}{% endif %}
  <p><span class="score {{ cls }}">{{ "%.1f"|format(s) }} / 100</span></p>

  <table>
    <thead><tr><th>Component</th><th>Weight</th><th>Value</th></tr></thead>
    <tbody>
    {% for comp, val in score.components.items() %}
      <tr><td>{{ comp }}</td><td>{{ "%.2f"|format(score.weights.get(comp, 0.0)) }}</td><td>{{ "%.4f"|format(val) }}</td></tr>
    {% endfor %}
    </tbody>
  </table>

  {% if score.substitutions %}
  <p><strong>Substitutions:</strong></p>
  <ul>
    {% for s in score.substitutions %}<li>{{ s }}</li>{% endfor %}
  </ul>
  {% endif %}

  <h2>MITRE ATT&amp;CK techniques</h2>
  {% if techniques %}
  <table>
    <thead><tr><th>ID</th><th>Name</th><th>Tactic</th><th>Matched via</th></tr></thead>
    <tbody>
    {% for t in techniques %}
      <tr><td><code>{{ t.id }}</code></td><td>{{ t.name }}</td><td>{{ t.tactic }}</td><td>{{ t.matched_via|join(", ") }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p><em>No technique matches.</em></p>
  {% endif %}

  <h2>Observations</h2>
  <table>
    <thead><tr><th>Kind</th><th>Value</th><th>Source</th><th>Severity</th><th>Confidence</th></tr></thead>
    <tbody>
    {% for o in observations %}
      <tr>
        <td><code>{{ o.kind }}</code></td>
        <td>{{ o.value }}</td>
        <td>{{ o.source }}</td>
        <td class="sev-{{ o.severity }}">{{ o.severity }}</td>
        <td>{{ o.confidence }}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if notes %}<h2>Notes</h2><pre>{{ notes }}</pre>{% endif %}

  <div class="footer">
    Generated by Mitiphy &middot; Apache-2.0 &middot; <a href="https://github.com/mitiphy/mitiphy">github.com/mitiphy/mitiphy</a>
  </div>
</body>
</html>
